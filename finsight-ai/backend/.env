# ============================================================
# FinSight AI — Environment Variables
# ============================================================

# Google Gemini API Key (required)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (production auth + portfolio persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Reddit API (for r/IndiaInvestments sentiment)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=FinSightAI/1.0

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Backend host/port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ChromaDB persistence path
CHROMA_PERSIST_DIR=./chroma_data

# SQLite path (dev mode paper trading)
SQLITE_DB_PATH=./finsight.db

# Scheduler interval (minutes)
SCHEDULER_INTERVAL_MIN=30

# RSS feed cache TTL (seconds)
RSS_CACHE_TTL=900
